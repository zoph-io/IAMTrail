{
    "PolicyVersion": {
        "Document": {
            "Version": "2012-10-17",
            "Statement": [
                {
                    "Sid": "SageMakerDataScienceAssistantAccess",
                    "Effect": "Allow",
                    "Action": [
                        "sagemaker-data-science-assistant:SendConversation"
                    ],
                    "Resource": "*",
                    "Condition": {
                        "StringEquals": {
                            "aws:ResourceAccount": "${aws:PrincipalAccount}"
                        }
                    }
                },
                {
                    "Sid": "AmazonQDeveloperAccess",
                    "Effect": "Allow",
                    "Action": [
                        "q:SendMessage",
                        "q:StartConversation"
                    ],
                    "Resource": "*",
                    "Condition": {
                        "StringEquals": {
                            "aws:ResourceAccount": "${aws:PrincipalAccount}"
                        }
                    }
                }
            ]
        },
        "VersionId": "v6",
        "IsDefaultVersion": true,
        "CreateDate": "2026-02-12T18:02:13+00:00"
    }
