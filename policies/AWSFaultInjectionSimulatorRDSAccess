                        "rds:RebootDBInstance"
                    ],
                    "Resource": [
                        "arn:aws:rds:*:*:db:*"
                    ]
                },
                {
                    "Sid": "DescribeResources",
                    "Effect": "Allow",
                    "Action": [
                        "rds:DescribeDBClusters",
                        "rds:DescribeDBInstances"
                    ],
                    "Resource": "*"
                },
                {
                    "Sid": "TargetResolutionByTags",
                    "Effect": "Allow",
                    "Action": [
                        "tag:GetResources"
                    ],
                    "Resource": "*"
                }
            ]
