{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3Objects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::zoph-lab-terraform-tfstate/mamip/*",
        "arn:aws:s3:::mamip-artifacts/*",
        "arn:aws:s3:::iamtrail.com/*"
      ]
    },
    {
      "Sid": "S3Buckets",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:CreateBucket",
        "s3:GetBucket*",
        "s3:PutBucket*",
        "s3:DeleteBucketPolicy",
        "s3:GetEncryptionConfiguration",
        "s3:GetLifecycleConfiguration",
        "s3:GetReplicationConfiguration",
        "s3:GetAccelerateConfiguration"
      ],
      "Resource": [
        "arn:aws:s3:::zoph-lab-terraform-tfstate",
        "arn:aws:s3:::iamtrail.com"
      ]
    },
    {
      "Sid": "GlobalReadAndMisc",
      "Effect": "Allow",
      "Action": [
        "iam:ListPolicies",
        "access-analyzer:ValidatePolicy",
        "sts:GetCallerIdentity",
        "ec2:Describe*",
        "ecr:GetAuthorizationToken",
        "ecs:DeregisterTaskDefinition",
        "ecs:RegisterTaskDefinition",
        "ecs:TagResource",
        "ecs:Describe*",
        "ecs:List*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ECS",
      "Effect": "Allow",
      "Action": "ecs:*",
      "Resource": [
        "arn:aws:ecs:*:567589703415:container-instance/*",
        "arn:aws:ecs:*:567589703415:service/*",
        "arn:aws:ecs:*:567589703415:task-set/*/*/*",
        "arn:aws:ecs:*:567589703415:task/*",
        "arn:aws:ecs:eu-west-1:567589703415:cluster/mamip_ecs_cluster_*",
        "arn:aws:ecs:eu-west-1:567589703415:task-definition/*"
      ]
    },
    {
      "Sid": "ECR",
      "Effect": "Allow",
      "Action": "ecr:*",
      "Resource": "arn:aws:ecr:eu-west-1:567589703415:repository/mamip-ecr-*"
    },
    {
      "Sid": "GlobalInfra",
      "Effect": "Allow",
      "Action": [
        "events:*",
        "logs:CreateLogGroup",
        "logs:DeleteLogGroup",
        "logs:Describe*",
        "logs:List*",
        "logs:PutRetentionPolicy",
        "logs:TagResource",
        "logs:TagLogGroup",
        "cloudwatch:PutMetricAlarm",
        "cloudwatch:DescribeAlarms",
        "cloudwatch:DeleteAlarms",
        "cloudwatch:ListTagsForResource",
        "cloudwatch:TagResource",
        "cloudfront:*Distribution*",
        "cloudfront:*CloudFrontOriginAccessIdentity*",
        "cloudfront:*Function*",
        "cloudfront:*Invalidation*",
        "cloudfront:TagResource",
        "cloudfront:UntagResource",
        "cloudfront:ListTagsForResource",
        "route53:*",
        "acm:*"
      ],
      "Resource": "*"
    }
  ]
}
